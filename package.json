{
  "name": "lets-release",
  "version": "8.1.0",
  "description": "Run automated workspace packages releasing",
  "author": "Sean Tu <manlao@gmail.com> (https://github.com/manlao)",
  "license": "MIT",
  "homepage": "https://github.com/lets-release/lets-release",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lets-release/lets-release.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "lets-release": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "prepare": "husky || true",
    "test": "vitest --config ./vitest.unit.config.ts",
    "test:cov": "vitest --config ./vitest.unit.config.ts --coverage.enabled",
    "test:e2e": "vitest --config ./vitest.e2e.config.ts",
    "test:workspace": "vitest --workspace ./vitest.vscode.workspace.ts",
    "type-check": "rimraf ./dist && tsc --build",
    "lint": "eslint --fix",
    "build": "rimraf ./dist && tspc --build tsconfig.build.json",
    "knip": "knip"
  },
  "dependencies": {
    "@lets-release/calver": "workspace:^",
    "@lets-release/config": "workspace:^",
    "@lets-release/semver": "workspace:^",
    "@lets-release/versioning": "workspace:^",
    "cac": "^7.0.0",
    "conventional-commits-parser": "^6.4.0",
    "cosmiconfig": "^9.0.2",
    "debug": "^4.4.3",
    "dir-glob": "^3.0.1",
    "env-ci": "^11.2.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "find-versions": "^6.0.0",
    "git-log-parser": "^1.2.1",
    "hook-std": "^4.0.0",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.5",
    "marked-terminal": "^7.3.0",
    "micromatch": "^4.0.8",
    "read-package-up": "^12.0.0",
    "read-pkg": "^10.1.0",
    "semver": "^7.8.4",
    "signale": "^1.4.0",
    "stream-to-array": "^2.3.0",
    "strip-ansi": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aliser/ts-transformer-append-js-extension": "^1.0.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@lets-release/testing": "workspace:^",
    "@types/debug": "^4.1.13",
    "@types/dir-glob": "^2.0.3",
    "@types/env-ci": "^3.1.4",
    "@types/git-log-parser": "^1.2.3",
    "@types/lodash-es": "^4.17.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.3",
    "@types/semver": "^7.7.1",
    "@types/signale": "^1.4.7",
    "@types/stream-buffers": "^3.0.8",
    "@types/stream-to-array": "^2.3.3",
    "@typescript-eslint/parser": "^8.61.0",
    "@typescript-eslint/utils": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^66.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "file-url": "^4.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "ncp": "^2.0.0",
    "p-retry": "^8.0.0",
    "prettier": "^3.8.4",
    "prettier-eslint": "^17.1.0",
    "rimraf": "^6.1.3",
    "stream-buffers": "^3.0.3",
    "tempy": "^3.2.0",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "typescript-transform-paths": "^4.0.0",
    "vite": "^8.0.16",
    "vite-node": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "package.json",
    "README.md",
    "dist/*",
    "!dist/*.tsbuildinfo"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "lets-release": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        1,
        "always",
        256
      ]
    }
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
